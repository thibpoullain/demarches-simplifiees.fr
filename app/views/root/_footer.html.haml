%footer.landing-footer{ role: 'contentinfo' }
  .container
    %ul.footer-columns

      %li.footer-column
        %ul.footer-logos
          %li.footer-text
            Un service fourni par la
            = link_to "DNUM", "https://solidarites-sante.gouv.fr/ministere/organisation/organisation-des-directions-et-services/article/organisation-de-la-direction-du-numerique-dnum", title: "Direction du Numérique des Ministères sociaux", :target => "_blank", rel: "noopener noreferrer"
            %br
            sur un socle logiciel fourni par la
            = link_to "DINUM", "https://numerique.gouv.fr/", title: "Direction Interministérielle au Numérique", :target => "_blank", rel: "noopener noreferrer"
            %br

      %li.footer-column
        %ul.footer-links
          %li.footer-link
            = link_to "solidarites-sante.gouv.fr", "https://solidarites-sante.gouv.fr", title: "Ministère des solidarités et de la santé", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "travail-emploi.gouv.fr", "https://travail-emploi.gouv.fr", title: "Ministère du travail, de l'emploi et de l'insertion", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "code.travail.gouv.fr", "https://code.travail.gouv.fr", title: "Code du travail numérique", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "service-public.fr", "https://www.service-public.fr", title: "Le site officiel de l'administration française", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "legifrance.gouv.fr", "https://www.legifrance.gouv.fr", title: "Le service public de la diffusion du droit", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "data.gouv.fr", "https://www.data.gouv.fr", title: "Plateforme ouverte des données publiques françaises", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "gouvernement.fr", "https://www.gouvernement.fr", title: "Gouverment.fr", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "france.fr", "https://www.france.fr", title: "France.fr : Actualités, destinations et infos du tourisme en France", :target => "_blank", rel: "noopener noreferrer"

      %li.footer-column
        %ul.footer-links
          %li.footer-link
            = link_to t("links.footer.cgu.usager.label"), t("links.footer.cgu.usager.url"), title: t("links.footer.cgu.usager.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to t("links.footer.cgu.agent.label"), t("links.footer.cgu.agent.url"), title: t("links.footer.cgu.agent.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to t("links.footer.mentions_legales.label"), t("links.footer.mentions_legales.url"), title: t("links.footer.mentions_legales.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to t("links.footer.confidentialite.label"), t("links.footer.confidentialite.url"), title: t("links.footer.confidentialite.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = contact_link t("links.footer.contact.label"), title: t("links.footer.contact.title"), class: "footer-link"
          %li.footer-link
            = link_to t("links.footer.doc.label"), t("links.footer.doc.url"), title: t("links.footer.doc.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to t("links.footer.faq.label"), t("links.footer.faq.url"), title: t("links.footer.faq.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to t("links.footer.accessibilite.label"), t("links.footer.accessibilite.url"), title: t("links.footer.accessibilite.title"), class: "footer-link", target: "_blank", rel: "noopener noreferrer"

