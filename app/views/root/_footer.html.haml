%footer.landing-footer{ role: 'contentinfo' }
  .container
    %ul.footer-columns

      %li.footer-column
        %ul.footer-logos
          %li.footer-text
            Un service fourni par la
            = link_to "DNUM", "https://solidarites-sante.gouv.fr/ministere/organisation/organisation-des-directions-et-services/article/organisation-de-la-direction-du-numerique-dnum", title: "Direction du Numérique des Ministères sociaux"
            %br
            sur un socle logiciel fourni par la
            = link_to "DINUM", "https://numerique.gouv.fr/", title: "Direction Interministérielle au Numérique"
            %br

      %li.footer-column
        %ul.footer-links
          %li.footer-link
            = link_to "solidarites-sante.gouv.fr", "https://solidarites-sante.gouv.fr", title: "Ministère des solidarités et de la santé",:target => "_blank"
          %li.footer-link
            = link_to "travail-emploi.gouv.fr", "https://travail-emploi.gouv.fr", title: "Ministère du travail, de l'emploi et de l'insertion",:target => "_blank"
          %li.footer-link
            = link_to "code.travail.gouv.fr", "https://code.travail.gouv.fr", title: "Code du travail numérique",:target => "_blank"
          %li.footer-link
            = link_to "service-public.fr", "https://www.service-public.fr", title: "Le site officiel de l'administration française",:target => "_blank"
          %li.footer-link
            = link_to "legifrance.gouv.fr", "https://www.legifrance.gouv.fr", title: "Le service public de la diffusion du droit",:target => "_blank"
          %li.footer-link
            = link_to "data.gouv.fr", "https://www.data.gouv.fr", title: "Plateforme ouverte des données publiques françaises",:target => "_blank"
          %li.footer-link
            = link_to "gouvernement.fr", "https://www.gouvernement.fr", title: "Gouverment.fr",:target => "_blank"
          %li.footer-link
            = link_to "france.fr", "https://www.france.fr", title: "France.fr : Actualités, destinations et infos du tourisme en France",:target => "_blank"

      %li.footer-column
        %ul.footer-links
          %li.footer-link
            = link_to "CGU", CGU_URL, :class => "footer-link", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "Mentions légales", MENTIONS_LEGALES_URL, :class => "footer-link", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = contact_link "Contact", class: "footer-link"
          %li.footer-link
            = link_to "Documentation", DOC_URL, :class => "footer-link", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to "FAQ", FAQ_URL, :class => "footer-link", :target => "_blank", rel: "noopener noreferrer"
          %li.footer-link
            = link_to ACCESSIBILITE_URL, :class => "footer-link", :target => "_blank", rel: "noopener noreferrer" do
              Accessibilité&nbsp;: non conforme
