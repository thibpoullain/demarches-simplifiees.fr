# Fichier contenant les paramétres à configurer impérativement et spécifiquement à l'environnement

# Nom d'hôte de l'appli (sans protocole)
#   * pour l'intégration : demat.integ.social.gouv.fr
#   * pour de la preprod: demat.pp.social.gouv.fr
#   * pour de la prod: demat.social.gouv.fr
# Est utilisé, notamment, pour générer les URL présents dans les mails émis par l'application
APP_HOST=demat-dev.social.gouv.fr:3000


# Clé de chiffrement de rails, cf https://api.rubyonrails.org/classes/Rails/Application.html
# Utilisée pour chiffrer les attributs encrypted_* des classes définies dans app/models
# Notamment : encrypted_password (super admin, admin, utilisateur) ; encrypted_token (admin) ; token de connexion pour les instructeurs
# Peut être générée aléatoirement MAIS ne doit plus être modifiée une fois des données en base
SECRET_KEY_BASE=05a2d479d8e412198dabd08ef0eee9d6e180f5cbb48661a35fd1cae287f0a93d40b5f1da08f06780d698bbd458a0ea97f730f83ee780de5d4e31f649a0130cf0
# Salage utilisé en complément du chiffrement précédent
ENCRYPTION_SERVICE_SALT=


# Clé de chiffrement OTP, pour 2FA
# Utilisée exclusivement pour l'authentification du super admin
# A générer en base 32
# Coté super admin, installer FreeOtp (de redhat / android store)
OTP_SECRET_KEY=JBSWY3DPEHPK3PXPJBSWY3DPEHPK3PXP


# Informations relatives à la base de données
DB_DATABASE=tps_development
DB_HOST=db
DB_POOL=
DB_USERNAME=tps_development
DB_PASSWORD=tps_development

# Object Storage pour les pièces jointes
# Usage S3
# valeur possible: enabled pour activer ; autre valeur sinon
S3_ENABLED=enabled
S3_ENDPOINT=https://storage-eb4.cegedim.cloud
S3_ACCESS_KEY_ID=pz805cjlf5qse2dfvm3i
S3_SECRET_ACCESS_KEY=H+lHpPyAIcQnJ54azsG2Hz4hW9Im6hnlOuAlWApi
S3_REGION=boulogne
S3_BUCKET=demat-dev.social.gouv.fr
# Le cas échéant, proxy HTTP (incluant protocole et port) pour connexion au service S3 (laisser vide en l'absence de proxy)
# Ex : https://monproxy.com:54321
# Cas d'utilisation : pour le(s) container jobs, indiquer ici l'URL du service ICAP
S3_HTTP_PROXY=
#Nb : si ni openstack, ni s3 ne sont enabled, alors bascule sur stockage local

#Configuration du serveur de mail
# Usage d'un serveur de mail SMTP conventionnel
SMTP_ENABLED=disabled
SMTP_USERNAME=
SMTP_PASSWORD=
#Ex : adresse du serveur mail cegedim ou social.gouv
SMTP_HOST=smtp.cegedim.cloud
#domaine cegedim ou, idéalement, social.gouv.fr si SPF configuré
SMTP_DOMAIN=smtp.cegedim.cloud
SMTP_PORT=25

# Service externe: Supervision exterieure via Sentry | Spécifique démarches-simplifiées.fr
SENTRY_ENABLED=enabled
SENTRY_DSN_RAILS=https://f4d9c29a9f724a30b2a77057c18a3c2c@sentry.fabrique.social.gouv.fr/66
SENTRY_DSN_JS=https://bc6410b127a94c4a928b1eb9e322cbf0@sentry.fabrique.social.gouv.fr/67
# Valeurs possibles à moduler selon l'env : development, integration, preproduction, production
SENTRY_CURRENT_ENV=development
# Capture de x % des appels, par échantillonage, pour mesure des perfs
# Commenter pour ne rien capturer
# 0.01 correspond à 1% des appels (0.01 * 100)
# En production, mettre un taux de 0.01 (1%)
# En integration et pproduction, mettre un taux de 1 (100%)
SENTRY_CAPTURE_RATE=1

# ==== Début ajout upgrade version DINUM 2022-04-14-01 ====

ACTIVE_STORAGE_SERVICE=local

# SAML Identity Provider
SAML_IDP_ENABLED=disabled

# External service: Matomo web analytics
MATOMO_COOKIE_DOMAIN=
MATOMO_DOMAIN=
MATOMO_HOST=
MATOMO_IFRAME_URL=

MAILCATCHER_ENABLED=disabled
MAILCATCHER_PORT=
MAILCATCHER_HOST=

LOGRAGE_SOURCE=tps_local

INVISIBLE_CAPTCHA_SECRET=kikooloool

CLAMAV_ENABLED=disabled

# ==== Fin ajout upgrade version DINUM 2022-04-14-01 ====

